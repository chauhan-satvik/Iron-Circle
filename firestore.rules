rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      // Hardcoded admin for the sector owner
      return isSignedIn() && (
        request.auth.token.email == 'satvikjansari@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- ADMINS COLLECTION ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    // --- GROUPS ---
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 

      // --- USERS WITHIN GROUPS ---
      match /users/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();

        // --- HABITS ---
        match /habits/{habitId} {
          allow read: if isOwner(userId) || isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/users/$(request.auth.uid)));
          allow create: if isOwner(userId) || isAdmin();
          allow update: if isOwner(userId) || isAdmin();
          allow delete: if isOwner(userId) || isAdmin();
        }

        // --- FOCUS SESSIONS ---
        match /focusSessions/{sessionId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) || isAdmin();
          allow update: if isOwner(userId) || isAdmin();
          allow delete: if isOwner(userId) || isAdmin();
        }

        // --- COMPLETIONS ---
        match /completions/{date} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    // Root users for global profile
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
