rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- GROUPS ---
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 

      // --- USERS WITHIN GROUPS ---
      match /users/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && isValidUser(incoming());
        allow update: if isOwner(userId) && isValidUser(incoming());
        allow delete: if isOwner(userId);

        function isValidUser(data) {
          return (data.get('uid', userId) == userId) &&
                 (data.get('displayName', '') is string) &&
                 (data.get('email', '') is string) &&
                 (data.get('xp', 0) is number) &&
                 (data.get('level', 0) is number) &&
                 (data.get('totalCompletions', 0) is number) &&
                 (data.get('globalStreak', 0) is number);
        }

        // --- HABITS ---
        match /habits/{habitId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidHabit(incoming());
          allow update: if isOwner(userId) && isValidHabit(incoming());
          allow delete: if isOwner(userId);

          function isValidHabit(data) {
            return (data.get('name', '') is string) && (data.get('name', '').size() <= 100) &&
                   (data.get('difficulty', 'easy') in ['easy', 'medium', 'hard']) &&
                   (data.get('type', 'daily') in ['daily', 'weekly']) &&
                   (data.get('target', 1) is number) &&
                   (data.get('xpValue', 10) is number) &&
                   (data.get('currentStreak', 0) is number) &&
                   (data.get('bestStreak', 0) is number);
          }
        }

        // --- COMPLETIONS ---
        match /completions/{date} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId) && isValidCompletion(incoming());

          function isValidCompletion(data) {
            return (data.get('date', '') is string) && 
                   (data.get('completions', {}) is map) &&
                   (data.get('xpEarned', 0) is number);
          }
        }
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Root users for backward compatibility/global profile
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
